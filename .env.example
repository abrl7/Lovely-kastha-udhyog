# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real credentials.

# MongoDB connection string.
# For local dev: mongodb://localhost:27017/lovely-kastha-udhog
# For MongoDB Atlas (free tier, recommended): get this from your Atlas
# cluster's "Connect" button -> "Drivers" -> copy the connection string,
# then replace <password> with your actual database user's password.
MONGODB_URI=mongodb://localhost:27017/lovely-kastha-udhog

# Required to register a new admin account through the signup form.
# This is the "invite code" gate: the signup form requires this value
# in addition to name/email/password, so random visitors can't create
# their own admin accounts just by finding the signup page. Share this
# value only with people who should have admin access (you, your dad).
# Make this a long, random string in production — not a guessable word.
ADMIN_SIGNUP_SECRET=change-this-to-something-only-you-and-dad-know

